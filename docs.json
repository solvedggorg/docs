{
    "$schema": "https://mintlify.com/docs.json",
    "theme": "mint",
    "name": "solved.gg Docs",
    "colors": {
        "primary": "#18181b",
        "light": "#f4f4f5",
        "dark": "#27272a"
    },
    "background": {
        "light": "#fafafa",
        "dark": "#070708"
    },
    "favicon": "/favicon.svg",
    "navigation": {
        "products": [
            {
                "product": "Home",
                "description": "Welcome to solved.gg docs and legal",
                "icon": "house",
                "groups": [
                    {
                        "group": "Welcome",
                        "pages": ["index"]
                    },
                    {
                        "group": "Legal",
                        "pages": [
                            "legal/privacy",
                            "legal/terms",
                            "legal/eula",
                            "legal/cla"
                        ]
                    }
                ]
            },
            {
                "product": "rusty",
                "description": "Cargo + rustup, rebuilt in Zig for Linux monorepos",
                "icon": "gears",
                "groups": [
                    {
                        "group": "Get started",
                        "pages": [
                            "rusty/index",
                            "rusty/quickstart",
                            "rusty/install"
                        ]
                    },
                    {
                        "group": "Core concepts",
                        "pages": [
                            "rusty/concepts/overview",
                            "rusty/concepts/project-formats",
                            "rusty/concepts/toolchains",
                            "rusty/concepts/store-and-cache"
                        ]
                    },
                    {
                        "group": "Guides",
                        "pages": [
                            "rusty/guides/build-and-test",
                            "rusty/guides/workspaces",
                            "rusty/guides/migrate-from-cargo"
                        ]
                    },
                    {
                        "group": "Reference",
                        "pages": [
                            "rusty/reference/cli",
                            "rusty/reference/environment"
                        ]
                    }
                ]
            },
            {
                "product": "scripty",
                "description": "JS runtime and project manager — Node, Deno, and Bun APIs in Zig",
                "icon": "code",
                "groups": [
                    {
                        "group": "Get started",
                        "pages": ["scripty/index"]
                    }
                ]
            },
            {
                "product": "worgo",
                "description": "Next-gen Go workspace project manager, written in Zig",
                "icon": "cube",
                "groups": [
                    {
                        "group": "Get started",
                        "pages": ["worgo/index"]
                    }
                ]
            }
        ],
        "global": {
            "anchors": [
                {
                    "anchor": "solved.gg",
                    "href": "https://solved.gg",
                    "icon": "globe"
                },
                {
                    "anchor": "Projects",
                    "href": "https://solved.gg/projects",
                    "icon": "grid-2"
                }
            ]
        }
    },
    "logo": {
        "light": "/logo/light.svg",
        "dark": "/logo/dark.svg",
        "href": "/"
    },
    "navbar": {
        "links": [
            {
                "label": "Legal",
                "href": "/legal/privacy"
            },
            {
                "label": "Support",
                "href": "mailto:intake@solved.gg"
            }
        ],
        "primary": {
            "type": "button",
            "label": "solved.gg",
            "href": "https://solved.gg"
        }
    },
    "contextual": {
        "options": [
            "copy",
            "view",
            "chatgpt",
            "claude",
            "perplexity",
            "mcp",
            "cursor",
            "vscode"
        ]
    },
    "footer": {
        "socials": {
            "website": "https://solved.gg",
            "discord": "https://discord.solved.gg",
            "podcast": "https://patreon.solved.gg"
        }
    }
}
